{
  "hooks": {
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bun run $CLAUDE_PROJECT_DIR/.claude/hooks/persistent-mode/index.ts",
            "timeout": 60
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bun run $CLAUDE_PROJECT_DIR/.claude/scripts/hud/index.ts"
  },
  "permissions": {
    "deny": [
      "Bash(rm -rf *)"
    ]
  }
}
