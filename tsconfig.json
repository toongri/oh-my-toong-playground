{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["bun-types"],
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "rootDir": ".",
    "baseUrl": ".",
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "paths": {
      "@lib/*": ["lib/*"]
    }
  },
  "include": ["lib/**/*.ts", "scripts/**/*.ts", "hooks/**/*.ts", "skills/*/scripts/**/*.ts", "tools/**/*.ts"]
}
